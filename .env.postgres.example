# ========================================
# St. Thomas Church - PostgreSQL Configuration
# ========================================
# Copy this file to .env and fill in your values

# Django Core Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-generate-with-python-c-from-django.core.management.utils-import-get_random_secret_key-print-get_random_secret_key

# Django Hosts & CORS
ALLOWED_HOSTS=localhost,127.0.0.1,your-vercel-domain.vercel.app,your-custom-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-domain.vercel.app,https://your-custom-domain.com

# ========== PostgreSQL Database ==========
# Get these from Neon.tech (free PostgreSQL hosting)
# 1. Go to https://neon.tech
# 2. Create a project
# 3. Copy the connection string format: postgresql://user:password@host/dbname
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your_host.neon.tech
DB_PORT=5432

# Frontend API (optional, if not set defaults to /api)
VITE_API_BASE_URL=https://your-domain.com/api

# Optional: AWS S3 for media files (recommended for production)
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
