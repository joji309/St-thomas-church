# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file - add it to .gitignore

# ─── DJANGO CORE SETTINGS ───────────────────────────────────────
DEBUG=False
SECRET_KEY=your-random-secret-key-here-generate-with-django-utils

# ─── DATABASE CONFIGURATION ────────────────────────────────────
# Option 1: SQLite (default - for development only)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Option 2: PostgreSQL (recommended for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=neondb
# DB_USER=neondb_owner
# DB_PASSWORD=your_neon_password
# DB_HOST=your_neon_host.neon.tech
# DB_PORT=5432

# ─── DEPLOYMENT SETTINGS ───────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-url.onrender.com

# ─── CORS SETTINGS ──────────────────────────────────────────────
# For development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# For production (Render)
# CORS_ALLOWED_ORIGINS=https://your-render-url.onrender.com

# ─── NOTES ──────────────────────────────────────────────────────
# To generate SECRET_KEY, run:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# On Render, set these as environment variables in the dashboard:
# 1. Go to Service Settings → Environment
# 2. Add each variable with its production value
# 3. For DATABASE, use PostgreSQL (Neon recommended - free tier available)
