{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": ["backend/**"] }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/admin(.*)", "dest": "api/index.py" },
    { "src": "/static/admin(.*)", "dest": "api/index.py" },
    { "src": "/media/(.*)", "dest": "api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "server.settings",
    "PYTHONPATH": "backend:.",
    "DEBUG": "False"
  }
}
