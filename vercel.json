{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": "backend/**"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/admin(.*)", "destination": "/api/index.py" },
    { "source": "/static/admin/(.*)", "destination": "/api/index.py" },
    { "source": "/media/(.*)", "destination": "/api/index.py" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "server.settings",
    "PYTHONUNBUFFERED": "1",
    "DEBUG": "False",
    "DISABLE_COLLECTSTATIC": "1",
    "PYTHONPATH": "backend"
  }
}
