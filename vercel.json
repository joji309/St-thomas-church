{
  "version": 2,
  "buildCommand": "npm --prefix frontend install && npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["backend/**", "frontend/dist/**"]
      }
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/admin(.*)", "dest": "/api/index.py" },
    { "src": "/static/admin(.*)", "dest": "/api/index.py" },
    { "src": "/media/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "server.settings",
    "PYTHONUNBUFFERED": "1",
    "DEBUG": "False",
    "DISABLE_COLLECTSTATIC": "1",
    "PYTHONPATH": "backend"
  }
}
